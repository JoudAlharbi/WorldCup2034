# Base URL for the authentication backend (login.php / signup.php live here).
# Local development default (used automatically if this variable is not set):
#   http://localhost/fifa-auth
# For production (e.g. Vercel), set this to your deployed auth API base URL:
#   https://your-auth-api.example.com
REACT_APP_AUTH_API_URL=http://localhost/fifa-auth

# NewsData.io API key used by the homepage news section (read in the frontend).
# Get a free key at https://newsdata.io. Create a file named ".env" in the project
# root with this line, then restart `npm start`:
#   REACT_APP_NEWSDATA_API_KEY=your_key_here
# Note: REACT_APP_* variables are embedded in the client bundle, so this key is
# visible to anyone who inspects the site. Use a free/restricted key for a portfolio.
REACT_APP_NEWSDATA_API_KEY=
